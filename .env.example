# Copy to .env and fill values
# LLM provider
# - openai: OPENAI_API_KEY 사용
# - github_models: GITHUB_TOKEN(GH_MODELS_TOKEN) 사용 (GitHub Models OpenAI-호환 엔드포인트)
LLM_PROVIDER=github_models

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# GitHub Models
GITHUB_TOKEN=ghp_...
GITHUB_MODELS_BASE_URL=https://models.inference.ai.azure.com

MEDIUM_INTEGRATION_TOKEN=your_medium_integration_token
DEFAULT_AUTHOR_ID=
# publish_status: draft | public | unlisted
DEFAULT_PUBLISH_STATUS=draft
DEFAULT_TAGS=programming,dev,python